# Copy this to secret.yaml and fill in real values.
# secret.yaml is gitignored — NEVER commit credentials.
#
# Or run setup.sh to generate it interactively.
apiVersion: v1
kind: Secret
metadata:
  name: opinai-credentials
  namespace: opinai
type: Opaque
stringData:
  GITHUB_TOKEN: "ghp_your_token_here"
  AI_API_KEY: "your_api_key_here"
  AI_BASE_URL: "https://api.anthropic.com"
  AI_MODEL: "claude-sonnet-4-20250514"
